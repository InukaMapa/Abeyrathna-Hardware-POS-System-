# Backend environment configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
# SUPABASE_SERVICE_KEY and SUPABASE_SERVICE_ROLE_KEY are also supported by the backend loader
# SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="Abeyrathna Trade Center Support" <no-reply@abeyrathnatradecenter.com>

# Optional AWS upload settings
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=chillgrand-images
